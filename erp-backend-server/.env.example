# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/erp_db

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_access_token_secret_min_64_chars
JWT_REFRESH_SECRET=your_refresh_token_secret_min_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Session ──────────────────────────────────────────────────────────────────
# How many devices can a single user be logged in from simultaneously
SESSION_MAX_CONCURRENT=5

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_GLOBAL=100
RATE_LIMIT_MAX_AUTH=10

# ─── Bcrypt ───────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Super Admin Seed (used only on first boot to seed the super admin) ───────
SUPER_ADMIN_EMAIL=superadmin@erp.com
SUPER_ADMIN_PASSWORD=SuperAdmin@123
SUPER_ADMIN_NAME=Super Admin
